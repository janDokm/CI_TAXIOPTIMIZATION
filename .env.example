# GEMINI_API_KEY: Required for API calls.
# This variable is loaded from secrets at runtime.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this platform is hosted.
# Injected at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
